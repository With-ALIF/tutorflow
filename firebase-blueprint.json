{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student in the tuition center",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "name": { "type": "string", "description": "Full name" },
        "class": { "type": "string", "description": "Class name" },
        "phone": { "type": "string", "description": "Phone number" },
        "subject": { "type": "string", "description": "Subject" },
        "address": { "type": "string", "description": "Address" },
        "monthly_fee": { "type": "number", "description": "Monthly fee" },
        "lectures_per_month": { "type": "number", "description": "Lectures per month" },
        "join_date": { "type": "string", "format": "date", "description": "Join date" }
      },
      "required": ["id", "name", "class", "phone"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": { "$ref": "Student" },
      "description": "Collection of students"
    }
  }
}
