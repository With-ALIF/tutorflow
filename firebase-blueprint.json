{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student in the tuition center",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "name": { "type": "string", "description": "Full name" },
        "class": { "type": "string", "description": "Class name" },
        "phone": { "type": "string", "description": "Phone number" },
        "subject": { "type": "string", "description": "Subject" },
        "address": { "type": "string", "description": "Address" },
        "monthly_fee": { "type": "number", "description": "Monthly fee" },
        "lectures_per_month": { "type": "number", "description": "Lectures per month" },
        "join_date": { "type": "string", "format": "date", "description": "Join date" }
      },
      "required": ["id", "name", "class", "phone"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance record for a student",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "student_id": { "type": "string", "description": "Student ID" },
        "date": { "type": "string", "format": "date", "description": "Date of attendance" },
        "status": { "type": "string", "enum": ["present", "absent"], "description": "Attendance status" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["student_id", "date", "status"]
    },
    "Fee": {
      "title": "Fee",
      "description": "Fee record for a student",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "student_id": { "type": "string", "description": "Student ID" },
        "amount": { "type": "number", "description": "Fee amount" },
        "payment_date": { "type": "string", "format": "date", "description": "Date of payment" },
        "fee_month": { "type": "string", "description": "Month of fee (YYYY-MM)" },
        "status": { "type": "string", "enum": ["paid", "due"], "description": "Fee status" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["student_id", "amount", "fee_month", "status"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": { "$ref": "Student" },
      "description": "Collection of students"
    },
    "/attendance/{attendanceId}": {
      "schema": { "$ref": "Attendance" },
      "description": "Collection of attendance records"
    },
    "/fees/{feeId}": {
      "schema": { "$ref": "Fee" },
      "description": "Collection of fee records"
    }
  }
}
